    "express": "^4.21.2",
    "dotenv": "^16.4.7",
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.5.0",
    "redis": "^4.7.0",
    "winston": "^3.17.0",
    "joi": "^17.13.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.4.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
