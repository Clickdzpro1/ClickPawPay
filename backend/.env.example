# ============================================================
# ClickPawPay — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to git (it is in .gitignore).
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,https://clickpawpay.com

# ── Database (PostgreSQL) ────────────────────────────────────
# Replace username, password, host, and dbname with your actual values.
DATABASE_URL="postgresql://username:password@localhost:5432/clickpawpay?schema=public"

# ── JWT Authentication ───────────────────────────────────────
# REQUIRED. Must be a long random string (min 32 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Token expiry duration (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# ── Encryption (AES-256-GCM for SlickPay keys) ───────────────
# REQUIRED. Must be exactly 64 lowercase hex characters (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: If you change this value, all stored API keys become unreadable.
ENCRYPTION_KEY=replace-with-64-hex-chars

# ── LLM Provider ─────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# REQUIRED for Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Optional: OpenAI as alternative provider
# OPENAI_API_KEY=sk-your-openai-key

# ── SlickPay API ──────────────────────────────────────────────
SLICKPAY_API_URL=https://api.slick-pay.com

# ── Agent Limits ─────────────────────────────────────────────
# Maximum messages kept in conversation history sent to the LLM
MAX_CONVERSATION_HISTORY=20

# Maximum characters allowed in a single user message
MAX_MESSAGE_LENGTH=4000

# Timeout for LLM API calls (milliseconds)
LLM_TIMEOUT_MS=60000

# Timeout for individual SlickPay tool executions (milliseconds)
TOOL_TIMEOUT_MS=30000

# ── Redis (required for distributed rate limiting) ────────────
# Falls back to in-process memory if Redis is unavailable (single instance only).
REDIS_URL=redis://localhost:6379

# ── Logging ───────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info

# Directory where log files are written (combined.log, error.log)
LOG_DIR=./logs
