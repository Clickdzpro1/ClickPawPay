# ClickPawPay — Docker Compose Environment Variables
# Copy this file to .env and fill in the values before running docker compose up
#
#   cp .env.example .env
#   nano .env                    # edit values
#   docker compose up --build -d
#
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme

# ── Authentication ───────────────────────────────────────────────────────────
# Random 64-hex-char string (32 bytes). Used to sign JWT tokens.
JWT_SECRET=

# ── Encryption ───────────────────────────────────────────────────────────────
# MUST be exactly 64 hex characters (32 bytes). Used for AES-256-GCM encryption
# of stored SlickPay API keys.
ENCRYPTION_KEY=

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
# Leave empty or "not-configured" to skip AI chat (registration & dashboard still work)
ANTHROPIC_API_KEY=

# ── CORS / Frontend URL ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Add your domain here in production.
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ── Frontend API URL (used at build time) ────────────────────────────────────
API_URL=http://localhost:3000
